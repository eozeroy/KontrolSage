<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:KontrolSage.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="KontrolSage.Views.DirectCostListView"
             x:DataType="vm:DirectCostListViewModel">

    <Grid>
        <!-- MAIN LIST VIEW -->
        <Grid IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNull}}" RowDefinitions="Auto, *">
            <!-- Header & Filters -->
            <Border Grid.Row="0" Padding="20" BorderBrush="#007ACC" BorderThickness="0,0,0,2">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Análisis del Costo Directo" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Presupuesto base e histórico por nodos de la Estructura de Trabajo" FontSize="14"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                        <TextBlock Text="Línea Base:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding AvailableBaselines}" SelectedItem="{Binding SelectedBaseline}" Width="100">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat='LB {0}'}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <Button Content="Fijar Línea Base Original" 
                                Command="{Binding CongelarBaselineOriginalAsync}" 
                                IsVisible="{Binding CanFreezeBaseline}"
                                FontWeight="Bold" ToolTip.Tip="Congela LB0 y crea LB1"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Data Table -->
            <Grid Grid.Row="1" Margin="20" RowDefinitions="*, Auto">
                <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,-20,0,0"/>

                <!-- Left-side EDT Tree could go here. For now just listing activities -->
                <DataGrid Grid.Row="0" Margin="0,10,0,0"
                          ItemsSource="{Binding ActividadesSource}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          GridLinesVisibility="All"
                          BorderThickness="1" BorderBrush="#E0E0E0"
                         >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Línea Base" Binding="{Binding Baseline, StringFormat='LB {0}'}" Width="100"/>
                        <DataGridTextColumn Header="N. EDT" Binding="{Binding EdtNodeId}" Width="150" />
                        <DataGridTextColumn Header="Inicio" Binding="{Binding Inicio, StringFormat='dd/MM/yyyy'}" Width="120" />
                        <DataGridTextColumn Header="Fin" Binding="{Binding Fin, StringFormat='dd/MM/yyyy'}" Width="120" />
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad, StringFormat='N2'}" Width="100" />
                        <DataGridTextColumn Header="Unidad" Binding="{Binding Unidad}" Width="80" />
                        <DataGridTextColumn Header="Costo Total" Binding="{Binding CostoDirectoTotal, StringFormat='C2'}" Width="150" />
                        
                        <DataGridTemplateColumn Header="Acciones" Width="100">
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                    <Button Content="📝" ToolTip.Tip="Analizar Costo / Editar" 
                                            Command="{Binding $parent[UserControl].((vm:DirectCostListViewModel)DataContext).EditActivityCommand}" 
                                            CommandParameter="{Binding}" Padding="5"/>
                                    <Button Content="🗑️" ToolTip.Tip="Eliminar" 
                                            Command="{Binding $parent[UserControl].((vm:DirectCostListViewModel)DataContext).EliminarActividadCommand}" 
                                            CommandParameter="{Binding}" Padding="5"
                                            IsVisible="{Binding !IsFrozen}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Footer Summary -->
                <Border Grid.Row="1" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="1,0,1,1">
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="{Binding TotalActivities, StringFormat='Actividades: {0}'}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="|" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='Importe Total: {0:C}'}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- EDITOR VIEW -->
        <ContentControl Content="{Binding CurrentEditor}" 
                        IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNotNull}}" />
    </Grid>
</UserControl>
