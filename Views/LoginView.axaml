<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:KontrolSage.ViewModels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="550"
             x:Class="KontrolSage.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="White">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#C0C0C0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#A0A0A0"/>
        </Style>
    </UserControl.Styles>
    
    <Border Padding="40">
        <StackPanel Spacing="0">
            <!-- Header Section -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,0,0,10">
                <!-- Icon Placeholder -->
                <PathIcon Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" 
                          Height="40" Width="40" Foreground="Black"/> 
                <TextBlock Text="Kontrol Sage" FontSize="32" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
            
            <TextBlock Text="Sistema de Control de Proyectos" FontSize="16" Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            
            <!-- Welcome Message Box -->
            <Border Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,0,0,25">
                <TextBlock Text="👋 ¡Bienvenido! Crea tu primera cuenta de administrador" 
                           Foreground="#1976D2" TextWrapping="Wrap" FontSize="14"/>
            </Border>
            
            <!-- Form -->
            <TextBlock Text="Correo Electrónico" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Email}" Watermark="Ingresa tu correo" Margin="0,0,0,15"/>
            
            <TextBlock Text="Contraseña" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Password}" Watermark="Ingresa tu contraseña" PasswordChar="*" Margin="0,0,0,15"/>
            
            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" 
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Margin="0,0,0,15"/>
            
            <!-- Login Button -->
            <Button Classes="primary" Content="Iniciar Sesión" Command="{Binding LoginCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,20"/>
            
            <!-- Register Link -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                <TextBlock Text="¿No tienes cuenta?" VerticalAlignment="Center" Foreground="#666666"/>
                <Button Content="Regístrate gratis (30 días)" Command="{Binding GoToRegisterCommand}" 
                        Background="Transparent" Foreground="#1976D2" BorderThickness="0" 
                        Padding="0" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Footer -->
            <TextBlock Text="Kontrol Sage v1.0 - Online" HorizontalAlignment="Center" 
                       Foreground="#999999" FontSize="12" Margin="0,30,0,0"/>
            
        </StackPanel>
    </Border>
</UserControl>
